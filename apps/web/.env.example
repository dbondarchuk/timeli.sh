# sandbox | production (defaults to sandbox when NODE_ENV is not production)
SQUARE_ENVIRONMENT=sandbox

# Stripe Connect OAuth (register redirect {ADMIN_URL}/apps/oauth/stripe/redirect and Connect client id ca_… in Stripe Dashboard → Connect → settings)
STRIPE_CONNECT_CLIENT_ID=
# Platform secret key (sk_…); used for OAuth token exchange and API calls with Stripe-Account (Connect)
STRIPE_SECRET_KEY=
# Platform publishable key (pk_…); returned to the booking UI for Stripe.js (Payment Element)
STRIPE_PUBLISHABLE_KEY=

# Stripe Connect (same as admin: OAuth + PaymentIntents on connected accounts; app API runs on web)
STRIPE_CONNECT_CLIENT_ID=
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Apple Pay: paste domain association from Stripe → Settings → Payment methods → Apple Pay (test vs live follows STRIPE_SECRET_KEY sk_test / sk_live)
# STRIPE_APPLE_PAY_DOMAIN_ASSOCIATION_TEST=
# STRIPE_APPLE_PAY_DOMAIN_ASSOCIATION_LIVE=
# STRIPE_APPLE_PAY_DOMAIN_ASSOCIATION=

# Redis Configuration for BullMQ
