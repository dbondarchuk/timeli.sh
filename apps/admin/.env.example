TAILWIND_MODE=watch
MONGODB_URI=mongodb://localhost:27017?retryWrites=true&w=majority
MONGODB_DB=timelish
PUBLIC_DOMAIN=timeli.sh
# IPv4 for custom-domain A records at apex/subdomain (optional). Shown in admin DNS help when set.
CUSTOM_DOMAIN_A_RECORD_IP=
ADMIN_DOMAIN=app.timelish.com
APPS_EXTERNAL_DOMAIN=apps.timelish.com
AUTH_PASSWORD=passwd
AUTH_SECRET="n6WKAtmUVdOYMRReNYXEd/sHLF/Ddfams+FAGMe7vzk=" 
SECRET_KEY="uw8iDFHFNjbIU8gPGMByTLiFfXJex7E1"
OUTLOOK_APP_CLIENT_ID=
OUTLOOK_APP_CLIENT_SECRET=
GOOGLE_CALENDAR_APP_CLIENT_ID=
GOOGLE_CALENDAR_APP_CLIENT_SECRET=
PAYPAL_ENVIRONMENT="sandbox"
# Square OAuth + Web Payments (register redirect {ADMIN_URL}/apps/oauth/square/redirect in Square Developer Console → OAuth)
SQUARE_APP_APPLICATION_ID=
SQUARE_APP_APPLICATION_SECRET=
# Application access token from the same Square application (Developer Dashboard → Credentials). Required for Webhook Subscriptions API (payment.updated); not the merchant OAuth token.
SQUARE_APP_ACCESS_TOKEN=
# sandbox | production (defaults to sandbox when NODE_ENV is not production)
SQUARE_ENVIRONMENT=sandbox
TEXTBELT_API_KEY=
# BETTER_AUTH_TRUST_HOST=https://timelishdev.studio
# BETTER_AUTH_URL=https://timelishdev.studio

# Redis Configuration for BullMQ
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0

# S3 Configuration for assets
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=
S3_BUCKET=
S3_FORCE_PATH_STYLE=

# BullMQ Queue Names
#BULLMQ_EMAIL_QUEUE_NAME=email-notifications
#BULLMQ_TEXT_MESSAGE_QUEUE_NAME=text-message-notifications

# Polar Subscriptions
# Absolute app URL for Polar checkout success/return redirects (defaults to request Host if unset)
# BETTER_AUTH_URL=https://your-admin-host
# ADMIN_URL=https://your-admin-host
# Create an Organization Access Token in your Polar dashboard settings (include customer_meters:read for SMS credit usage in admin)
POLAR_ACCESS_TOKEN=
# Signing secret from your Polar webhook endpoint configuration
POLAR_WEBHOOK_SECRET=
# Comma-separated slug:productId pairs (add matching benefit keys per slug in polar-billing.ts)
# Example: POLAR_BILLING_PLANS=pro:prod_xxx,starter:prod_yyy
POLAR_BILLING_PLANS=
# "sandbox" for testing, "production" for live payments
POLAR_SERVER=sandbox
# Event name matching the SMS meter filter in Polar (usage ingest from TextBelt send/reply)
POLAR_SMS_USAGE_EVENT_NAME=
# Same meter id as the SMS credit benefit (used to gate built-in TextBelt sends via customer meters API)
POLAR_SMS_CREDITS_METER_ID=
# Optional: price line shown on the install Pro card (must match your Polar product; overrides install locale default)
NEXT_PUBLIC_PRO_SUBSCRIPTION_PRICE=