{
  "name": "@timelish/i18n",
  "version": "0.0.1",
  "private": true,
  "sideEffects": false,
  "scripts": {
    "type-check": "tsc --pretty --noEmit",
    "type-check:ci": "tsc-absolute --pretty --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "generate-locales": "node scripts/generate-locales-from-yaml.mjs",
    "typegen": "node scripts/generate-locales-from-yaml.mjs",
    "check-translations": "node scripts/check-translations.js",
    "translate": "node scripts/translate-missing-locale-keys.js"
  },
  "exports": {
    ".": "./src/index.ts",
    "./server": "./src/server.ts",
    "./request": "./src/request.ts"
  },
  "devDependencies": {
    "@timelish/eslint-config": "*",
    "@timelish/typescript-config": "*",
    "typescript": "5.5.4"
  },
  "dependencies": {
    "next-intl": "^4.3.9",
    "yaml": "^2.7.0"
  }
}
